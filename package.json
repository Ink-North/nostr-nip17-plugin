{
  "name": "nostr-nip17",
  "version": "0.1.1",
  "description": "OpenClaw Nostr DM channel plugin with NIP-04, NIP-17, and multi-account support",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "openclaw",
    "nostr",
    "nip17",
    "nip04",
    "plugin",
    "channel",
    "dm"
  ],
  "files": [
    "src",
    "openclaw.plugin.json",
    "PUBLISHING.md",
    "nostr-doc.md"
  ],
  "dependencies": {
    "@noble/hashes": "^1.8.0",
    "nostr-tools": "^2.17.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.4.12"
  },
  "openclaw": {
    "extensions": [
      "./src/index.portable.js"
    ],
    "setupEntry": "./src/setup-entry.portable.js",
    "channel": {
      "id": "nostr",
      "label": "Nostr NIP-17",
      "selectionLabel": "Nostr (NIP-04 + NIP-17 DMs)",
      "docsLabel": "nostr-nip17",
      "docsPath": "/channels/nostr",
      "blurb": "Nostr direct messages with NIP-04, NIP-17, and multi-account support.",
      "order": 55,
      "quickstartAllowFrom": true
    },
    "install": {
      "npmSpec": "@openclaw/nostr-nip17",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.12"
    },
    "compat": {
      "pluginApi": ">=2026.4.12"
    },
    "bundle": {
      "stageRuntimeDependencies": true
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
